#compdef tgrep

autoload -U is-at-least

_tgrep() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--live-delay=[milliseconds to wait after the last keystroke before triggering a live search]::_default' \
'-C+[number of lines to show before and after each match]::_default' \
'--context=[number of lines to show before and after each match]::_default' \
'--branch-len=[number of characters to show before a match]::_default' \
'--threads=[set the number of threads to use]::_default' \
'--editor=[command used to open selections]::_default' \
'--open-like=[command line syntax for opening a file at a line]::(vi hx code jed default)' \
'--completions=[generate completions for given shell]::(bash elvish fish powershell zsh nushell)' \
'--file-color=[black, white, red, green, yellow, blue, magenta, cyan, grey, rgb(_._._), ansi(_)]::_default' \
'--dir-color=[black, white, red, green, yellow, blue, magenta, cyan, grey, rgb(_._._), ansi(_)]::_default' \
'--text-color=[black, white, red, green, yellow, blue, magenta, cyan, grey, rgb(_._._), ansi(_)]::_default' \
'--branch-color=[black, white, red, green, yellow, blue, magenta, cyan, grey, rgb(_._._), ansi(_)]::_default' \
'--line-number-color=[black, white, red, green, yellow, blue, magenta, cyan, grey, rgb(_._._), ansi(_)]::_default' \
'*--match-colors=[black, white, red, green, yellow, blue, magenta, cyan, grey, rgb(_._._), ansi(_)]::_default' \
'--selected-indicator-color=[black, white, red, green, yellow, blue, magenta, cyan, grey, rgb(_._._), ansi(_)]::_default' \
'--selected-bg-color=[black, white, red, green, yellow, blue, magenta, cyan, grey, rgb(_._._), ansi(_)]::_default' \
'--filter-highlight-color=[black, white, red, green, yellow, blue, magenta, cyan, grey, rgb(_._._), ansi(_)]::_default' \
'--char-vertical=[vertical branch character]::_default' \
'--char-horizontal=[horizontal branch character]::_default' \
'--char-top-left=[top-left corner character]::_default' \
'--char-top-right=[top-right corner character]::_default' \
'--char-bottom-left=[bottom-left corner character]::_default' \
'--char-bottom-right=[bottom-right corner character]::_default' \
'--char-tee=[tee branch character]::_default' \
'--ellipsis=[folded indicator]::_default' \
'--search-prompt=[search mode prompt]::_default' \
'--search-prompt-inactive=[search prompt when not searching]::_default' \
'--filter-prompt=[filter mode prompt]::_default' \
'--selected-indicator=[selected indicator characters]::_default' \
'*--key-down=[move down]::_default' \
'*--key-up=[move up]::_default' \
'*--key-big-down=[big jump down]::_default' \
'*--key-big-up=[big jump up]::_default' \
'*--key-down-path=[move down to the next path]::_default' \
'*--key-up-path=[move up to the previous path]::_default' \
'*--key-down-same-depth=[move down to the next path at same depth]::_default' \
'*--key-up-same-depth=[move up to the previous path at same depth]::_default' \
'*--key-top=[move to the top]::_default' \
'*--key-bottom=[move to the bottom]::_default' \
'*--key-page-down=[page down]::_default' \
'*--key-page-up=[page up]::_default' \
'*--key-cycle-view=[cycle cursor position (top/center/bottom)]::_default' \
'*--key-help=[show help]::_default' \
'*--key-quit=[quit]::_default' \
'*--key-open=[open selection]::_default' \
'*--key-fold=[fold/unfold path]::_default' \
'*--key-fold-cycle=[cycle global fold (dirs/files/none)]::_default' \
'*--key-filter=[filter within results]::_default' \
'*--key-search=[enter search mode]::_default' \
'*--key-submit-search=[submit search query]::_default' \
'--selection-file=[file to write selection to]::_files' \
'--repeat-file=[file to save and replay regexp searches]::_files' \
'*-e+[a regex expression to search for (saved for repeat)]::' \
'*--regexp=[a regex expression to search for (saved for repeat)]::' \
'*--regexp-glob=[search for a regex expression only in files matching a glob (saved for repeat)]:glob=regexp:_default' \
'-p+[the path to search, if not provided, search the current directory (saved for repeat)]::_files' \
'--path=[the path to search, if not provided, search the current directory (saved for repeat)]::_files' \
'*-g+[rules match .gitignore globs, but ! has inverted meaning, overrides other ignore logic (saved for repeat)]::_default' \
'*--glob=[rules match .gitignore globs, but ! has inverted meaning, overrides other ignore logic (saved for repeat)]::_default' \
'-d+[the max depth to search (saved for repeat)]::_default' \
'--max-depth=[the max depth to search (saved for repeat)]::_default' \
'--max-length=[set the max length for a matched line (saved for repeat)]::_default' \
'-B+[number of lines to show before each match (saved for repeat)]::_default' \
'--before-context=[number of lines to show before each match (saved for repeat)]::_default' \
'-A+[number of lines to show after each match (saved for repeat)]::_default' \
'--after-context=[number of lines to show after each match (saved for repeat)]::_default' \
'--branch-each=[number of files to print on each branch (saved for repeat)]::_default' \
'-s[results are shown in a selection interface for opening]' \
'--select[results are shown in a selection interface for opening]' \
'-m[open a search and selection interface]' \
'--menu[open a search and selection interface]' \
'--live[trigger search on every keystroke in the menu]' \
'--auto-open[if there is only one match, open it in the configured editor]' \
'--repeat[repeats the last saved search]' \
'--no-color[disable colors]' \
'--no-bold[disable bold]' \
'--no-mouse[disable mouse events]' \
'--no-alternate-screen[disable the terminal alternate screen]' \
'-h[]' \
'--help[]' \
'-V[]' \
'--version[]' \
'-.[search hidden files (saved for repeat)]' \
'--hidden[search hidden files (saved for repeat)]' \
'-n[show the line numbers of matches (saved for repeat)]' \
'--line-number[show the line numbers of matches (saved for repeat)]' \
'-f[if an expression is given, hide matched content, otherwise, show the files that would be searched (saved for repeat)]' \
'--files[if an expression is given, hide matched content, otherwise, show the files that would be searched (saved for repeat)]' \
'-c[display number of files matched in directory and number of lines matched in a file (saved for repeat)]' \
'--count[display number of files matched in directory and number of lines matched in a file (saved for repeat)]' \
'-l[search linked paths (saved for repeat)]' \
'--links[search linked paths (saved for repeat)]' \
'--trim[trim whitespace at the beginning of lines (saved for repeat)]' \
'--no-ignore[disable ignore files (saved for repeat)]' \
'-o[conclude results with an overview (saved for repeat)]' \
'--overview[conclude results with an overview (saved for repeat)]' \
'-S[only show the overview, not the results (saved for repeat)]' \
'--overview-only[only show the overview, not the results (saved for repeat)]' \
'--pcre2[use PCRE2 instead of the default regex engine (saved for repeat)]' \
'::positional_regexp -- a regex expression to search for:' \
'::positional_path -- the path to search, if not provided, search the current directory:_files' \
&& ret=0
}

(( $+functions[_tgrep_commands] )) ||
_tgrep_commands() {
    local commands; commands=()
    _describe -t commands 'tgrep commands' commands "$@"
}

if [ "$funcstack[1]" = "_tgrep" ]; then
    _tgrep "$@"
else
    compdef _tgrep tgrep
fi
